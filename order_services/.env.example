# Order Service Configuration

# Server
APP_HOST=127.0.0.1
APP_PORT=8007
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000,http://localhost:8080

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=abt_order_db
DB_USER=root
DB_PASS=Gaurav@123
DB_URL=mysql+pymysql://root:Gaurav@123@localhost:3306/abt_order_db

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
INTERNAL_SERVICE_TOKEN=

# Payment Service
PAYMENT_SERVICE_BASE_URL=http://127.0.0.1:8006
PAYMENT_STATUS_TIMEOUT_SECONDS=5

# Delivery notifications
ENABLE_ORDER_NOTIFICATIONS=true
TWILIO_SID=
TWILIO_AUTH=
TWILIO_PHONE=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Stock
ENABLE_STOCK_RESERVATION=false
DEDUCT_STOCK_ON_ORDER=false
